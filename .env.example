# Django Settings for Production
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-using-django-admin-startproject
ALLOWED_HOSTS=localhost,127.0.0.1,your-render-app-url.onrender.com

# Database (Render will provide this automatically)
# Example: postgres://user:password@host:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3

# Optional: Email settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
